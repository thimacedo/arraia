@@ -0,0 +1,21 @@
+import { Redis } from "@upstash/redis"
+
+// Cliente Redis (Upstash) — usado como banco compartilhado da lista da festa.
+// As variáveis KV_REST_API_URL / KV_REST_API_TOKEN são injetadas automaticamente
+// pela Vercel quando você conecta uma integração "Upstash for Redis" (ou "Vercel KV")
+// ao projeto. UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN também são aceitas
+// caso você prefira criar o banco direto no console da Upstash.
+function getRedis(): Redis | null {
+  const url =
+    process.env.KV_REST_API_URL || process.env.UPSTASH_REDIS_REST_URL
+  const token =
+    process.env.KV_REST_API_TOKEN || process.env.UPSTASH_REDIS_REST_TOKEN
+
+  if (!url || !token) return null
+  return new Redis({ url, token })
+}
+
+export const redis = getRedis()
+
+// Chave única onde o snapshot completo da festa é guardado.
+export const FESTA_STATE_KEY = "festa-junina:state"
